# AI Provider 配置（默认 GLM 国内端点，零梯子可达）
# 任选一个，把对应 key 填到 .env.local

# === GLM（默认，国内可达，免费额度） ===
AI_PROVIDER=glm
GLM_API_KEY=your-glm-api-key

# === DeepSeek（国内可达） ===
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your-deepseek-api-key

# === 小米 MiMo（国内可达） ===
# AI_PROVIDER=mimo
# MIMO_API_KEY=your-mimo-api-key

# === 通用配置（优先级最高） ===
# AI_API_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4-flash
# AI_API_KEY=your-key

# === 公开主页认证 token（访客 PUT 时需带） ===
NEXT_PUBLIC_PUBLIC_AUTH_TOKEN=dev-token-change-in-prod
PUBLIC_AUTH_TOKEN=dev-token-change-in-prod

# === Cloudflare Pages 静态导出（部署用） ===
# NEXT_PUBLIC_STATIC_EXPORT=true
